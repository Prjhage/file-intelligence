{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "File Intelligence",
  "version": "1.0.0",
  "identifier": "com.hagep.file-intelligence",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1460",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "File Intelligence",
        "width": 400,
        "height": 700,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": true,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/file-intelligence-backend"]
  }
}
